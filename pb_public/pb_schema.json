[
  {
    "name": "broadcasts",
    "type": "base",
    "fields": [
      { "name": "title", "type": "text", "required": true, "options": { "min": 1, "max": 80 } },
      { "name": "message", "type": "text", "required": true, "options": { "min": 1, "max": 700 } },
      { "name": "priority", "type": "select", "required": true, "values": ["urgent", "important", "general"], "maxSelect": 1 },
      { "name": "image", "type": "file", "required": false, "options": { "maxSelect": 1, "maxSize": 10485760, "mimeTypes": ["image/jpeg", "image/png", "image/webp"] } },
      { "name": "created_by", "type": "relation", "required": false, "collectionId": "_pb_users_auth_", "maxSelect": 1 },
      { "name": "is_active", "type": "bool", "required": false }
    ],
    "listRule": "is_active = true",
    "viewRule": "is_active = true",
    "createRule": "@request.auth.id != '' && @request.auth.role = 'admin'",
    "updateRule": "@request.auth.id != '' && @request.auth.role = 'admin'",
    "deleteRule": "@request.auth.id != '' && @request.auth.role = 'admin'"
  },
  {
    "name": "broadcast_reads",
    "type": "base",
    "fields": [
      { "name": "broadcast", "type": "relation", "required": true, "collectionId": "broadcasts", "maxSelect": 1 },
      { "name": "device_id", "type": "text", "required": true, "options": { "min": 8, "max": 120 } }
    ],
    "listRule": "",
    "viewRule": "",
    "createRule": "1 = 1",
    "updateRule": "1 = 1",
    "deleteRule": "@request.auth.id != '' && @request.auth.role = 'admin'"
  }
]
